PORT=4000
CLIENT_ORIGIN=http://localhost:3000

# Preferred Atlas format when Node.js can resolve SRV DNS records.
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.f6pq3gx.mongodb.net/glossy?retryWrites=true&w=majority&appName=Cluster0

# Fallback format when Node.js refuses the mongodb+srv SRV lookup.
# Replace USER and PASSWORD, then use this as MONGODB_URI in .env:
# mongodb://USER:PASSWORD@ac-kxwb6x9-shard-00-00.f6pq3gx.mongodb.net:27017,ac-kxwb6x9-shard-00-01.f6pq3gx.mongodb.net:27017,ac-kxwb6x9-shard-00-02.f6pq3gx.mongodb.net:27017/glossy?ssl=true&authSource=admin&replicaSet=atlas-1tst7d-shard-0&retryWrites=true&w=majority&appName=Cluster0

# Optional: only use this if these resolvers are reachable from your network.
# DNS_SERVERS=1.1.1.1,8.8.8.8

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
ADMIN_KEY=
